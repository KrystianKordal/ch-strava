# --- Strava (z https://www.strava.com/settings/api) ---
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Bazowy URL aplikacji (do callbacku OAuth). Lokalnie zwykle:
#   http://localhost:3000
# Na Vercel ustaw na adres produkcyjny, np. https://twoja-app.vercel.app
APP_URL=http://localhost:3000

# --- Turso / libSQL ---
# Lokalnie możesz zostawić puste — użyje pliku file:./data/local.db
# Produkcyjnie (Vercel) wklej dane z `turso db show` i `turso db tokens create`:
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Sekret chroniący ręczny trigger /api/poll przed publicznym wywołaniem.
# Odpalasz polling sam: /api/poll?key=<POLL_SECRET>
# (albo nagłówkiem Authorization: Bearer <POLL_SECRET>).
# Zostaw puste = endpoint otwarty (wygodne lokalnie, NIE na produkcji).
POLL_SECRET=

# Pozwól na endpoint /api/seed z danymi demo (tylko do testów: 1 = wł.)
ALLOW_SEED=1
