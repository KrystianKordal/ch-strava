# --- Strava (z https://www.strava.com/settings/api) ---
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Bazowy URL aplikacji (do callbacku OAuth). Lokalnie zwykle:
#   http://localhost:3000
# Na Vercel ustaw na adres produkcyjny, np. https://twoja-app.vercel.app
APP_URL=http://localhost:3000

# --- Supabase / Postgres ---
# Connection string z Supabase: Project → Settings → Database.
# Na produkcji (Vercel/serverless) użyj poolera "Transaction" (port 6543), np.:
#   postgres://postgres.<ref>:<HASLO>@aws-0-<region>.pooler.supabase.com:6543/postgres
# Lokalnie możesz wskazać ten sam string albo własnego Postgresa.
# (Integracja Vercel ↔ Supabase ustawia też POSTGRES_URL — to też zadziała.)
DATABASE_URL=

# Sekret chroniący ręczny trigger /api/poll i /api/manual przed publicznym
# wywołaniem. Odpalasz polling sam: /api/poll?key=<POLL_SECRET>
# (albo nagłówkiem Authorization: Bearer <POLL_SECRET>).
# Puste = otwarte TYLKO lokalnie; w produkcji endpointy są wtedy zamknięte
# (fail-closed). Na produkcji USTAW długi, losowy sekret.
POLL_SECRET=

# Hasło do dashboardu (HTTP Basic Auth na '/' i '/api/stats').
# Przy logowaniu login może być dowolny — liczy się hasło.
# Puste = brak ochrony lokalnie; w produkcji dashboard zwraca 503 (fail-closed).
# USTAW na produkcji!
DASHBOARD_PASSWORD=

# Klucz szyfrujący tokeny Stravy w bazie (AES-256-GCM). Dowolny format/długość
# (jest haszowany do 32 bajtów). Wygeneruj np.:  openssl rand -hex 32
# W PRODUKCJI WYMAGANY (bez niego zapis tokenu rzuci błędem). Lokalnie puste =
# tokeny zapisywane plaintext (wygoda dev). NIE zmieniaj po starcie — zmiana
# klucza unieważni już zapisane tokeny (trzeba autoryzować drużyny ponownie).
TOKEN_ENCRYPTION_KEY=

# Pozwól na endpoint /api/seed z danymi demo (tylko lokalnie: 1 = wł.).
# Na produkcji endpoint jest zablokowany niezależnie od tej wartości.
ALLOW_SEED=0
